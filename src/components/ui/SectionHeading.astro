---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-10 md:mb-12">
  <h2 class="text-2xl font-semibold tracking-tight text-text-primary md:text-3xl">
    {title}
  </h2>
  {
    subtitle && (
      <p class="mt-2 max-w-2xl text-base text-text-secondary">{subtitle}</p>
    )
  }
  <div class="mt-4 h-px w-12 bg-accent" />
</div>
