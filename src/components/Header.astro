---
const navLinks = [
  { href: "#projects", label: "Projects" },
  { href: "#experience", label: "Experience" },
  { href: "#contact", label: "Contact" },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-border-subtle bg-surface/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4"
    aria-label="Main navigation"
  >
    <a
      href="#"
      class="font-mono text-sm font-medium text-text-primary transition-colors hover:text-accent"
    >
      Portfolio
    </a>

    <ul class="flex items-center gap-1 sm:gap-2">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="rounded-md px-3 py-2 text-sm text-text-secondary transition-colors hover:text-text-primary"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
